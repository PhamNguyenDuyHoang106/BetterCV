{
  "name": "bettercv",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "build:packages": "npm --workspace packages/shared run build && npm --workspace packages/template-engine run build",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm run build:packages && npm --workspace apps/api run build",
    "build:admin": "npm --workspace apps/admin run build",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:api": "npm --workspace apps/api run lint",
    "db:generate": "npm --workspace apps/api run prisma:generate",
    "db:migrate": "npm --workspace apps/api run prisma:migrate",
    "db:seed": "npm --workspace apps/api run prisma:seed",
    "generate:thumbnails": "npm run generate:thumbnails --prefix packages/template-engine",
    "seed:users": "node scripts/seed-users.mjs",
    "update:avatars": "node scripts/update-avatars.mjs",
    "update:avatars:force": "node scripts/update-avatars.mjs --force",
    "update:avatars:dry": "node scripts/update-avatars.mjs --dry-run"
  },
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "@acv/template-engine": "^0.1.0",
    "@payos/node": "^2.0.5",
    "jwks-rsa": "^3.2.2"
  }
}
