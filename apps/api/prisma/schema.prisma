generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  passwordHash     String?
  fullName         String
  avatarUrl        String?
  role             UserRole        @default(FREE)
  supabaseId       String?         @unique
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  aiUsages         AiUsage[]
  cvs              Cv[]
  invoices         Invoice[]
  ocrJobs          OcrJob[]
  stripeCustomer   StripeCustomer?
  subscriptions    Subscription[]
  usageQuota       UsageQuota?
  payosTransactions PayosTransaction[]
  careerRoadmaps   CareerRoadmap[]
  coachSessions    CareerCoachSession[]
  aiUsageLogs      AiUsageLog[]

  @@index([email])
  @@index([supabaseId])
}

model Plan {
  id             String         @id @default(cuid())
  tier           PlanTier       @unique
  name           String
  monthlyAiQuota Int
  stripePriceId  String?        @unique
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  planId               String
  status               String
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  plan                 Plan      @relation(fields: [planId], references: [id])
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model StripeCustomer {
  id         String   @id @default(cuid())
  userId     String   @unique
  customerId String   @unique
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  currency  String   @default("usd")
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Cv {
  id                   String           @id @default(cuid())
  userId               String
  title                String
  locale               String           @default("en")
  templateId           String?
  isDeleted            Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  lastEditedAt         DateTime?
  lastEditedDevice     String?
  lastEditedSessionId  String?
  version              Int              @default(1)
  templateVersionId    String?
  templateVersionNum   Int              @default(1)
  atsScore             Int?
  completenessScore    Int?
  thumbnailGeneratedAt DateTime?
  thumbnailUrl         String?
  atsScannedAt         DateTime?
  atsVersion           String?
  thumbnailStatus      ThumbnailStatus  @default(PENDING)
  thumbnailAttemptCount Int              @default(0)
  thumbnailLastError    String?
  atsScans             AtsScan[]
  templateVersion      TemplateVersion? @relation(fields: [templateVersionId], references: [id])
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections             CvSection[]
  versions             CvVersion[]
  shareLinks           ShareLink[]

  @@index([userId])
  @@index([userId, isDeleted])
  @@index([updatedAt, thumbnailGeneratedAt])
}

model CvVersion {
  id        String   @id @default(cuid())
  cvId      String
  snapshot  Json
  createdAt DateTime @default(now())
  cv        Cv       @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
}

model CvSection {
  id        String        @id @default(cuid())
  cvId      String
  type      CvSectionType
  content   Json
  order     Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  cv        Cv            @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@index([cvId, type])
}

model TemplateCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  templates Template[]
}

model Template {
  id         String            @id @default(cuid())
  name       String
  categoryId String
  schema     Json
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  category   TemplateCategory  @relation(fields: [categoryId], references: [id])
  versions   TemplateVersion[]

  @@index([categoryId])
  @@index([isActive])
}

model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  version    Int      @default(1)
  schema     Json
  createdAt  DateTime @default(now())
  cvs        Cv[]
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId])
}

model ShareLink {
  id        String    @id @default(cuid())
  cvId      String
  token     String    @unique
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  cv        Cv        @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([token])
}

model AtsScan {
  id                 String   @id @default(cuid())
  cvId               String
  cv                 Cv       @relation(fields: [cvId], references: [id], onDelete: Cascade)
  jobTitle           String?
  jobDescription     String?  @db.Text
  jobDescriptionHash String?
  overallScore       Int?
  keywordScore       Int?
  formatScore        Int?
  completenessScore  Int?
  semanticScore      Int?
  experienceScore    Int?
  skillsScore        Int?
  aiModel            String?
  promptVersion      String?
  contentHash        String?
  missingKeywords    Json?
  recommendations    Json?
  createdAt          DateTime @default(now())
  careerRoadmaps     CareerRoadmap[]

  @@index([cvId, createdAt(sort: Desc)])
  @@index([cvId, contentHash])
}

model Prompt {
  id        String          @id @default(cuid())
  key       String          @unique
  createdAt DateTime        @default(now())
  versions  PromptVersion[]
}

model PromptVersion {
  id        String   @id @default(cuid())
  promptId  String
  version   Int
  content   String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId, isActive])
}

model AiRequest {
  id              String          @id @default(cuid())
  userId          String?
  promptKey       String
  input           Json
  createdAt       DateTime        @default(now())
  estimatedTokens Int?
  status          AiRequestStatus @default(PENDING)
  idempotencyKey  String?         @unique

  @@index([userId])
  @@index([status, createdAt])
}

model AiResponse {
  id        String   @id @default(cuid())
  requestId String
  output    Json
  tokens    Int
  createdAt DateTime @default(now())

  @@index([requestId])
}

model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  tokens    Int
  requests  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UsageQuota {
  id           String   @id @default(cuid())
  userId       String   @unique
  periodStart  DateTime
  periodEnd    DateTime
  usedTokens   Int      @default(0)
  usedRequests Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SafetyRule {
  id        String   @id @default(cuid())
  name      String   @unique
  pattern   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model OcrJob {
  id            String       @id @default(uuid())
  userId        String
  filename      String
  status        OcrJobStatus @default(UPLOADED)
  extractedCvId String?
  error         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PayosTransaction {
  id            String   @id @default(cuid())
  userId        String
  orderCode     Int      @unique
  amount        Int

  status        String
  mode          String
  tier          String

  description   String?
  checkoutUrl   String?
  paymentLinkId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum UserRole {
  GUEST
  FREE
  PRO
  PREMIUM
  ADMIN
}

enum PlanTier {
  FREE
  PRO
  PREMIUM
}

enum OcrJobStatus {
  UPLOADED
  QUEUED
  PROCESSING
  REVIEWING
  COMPLETED
  FAILED
}

enum CvSectionType {
  PROFILE
  SUMMARY
  EXPERIENCE
  EDUCATION
  SKILLS
  PROJECTS
  LANGUAGES
  CERTIFICATIONS
  AWARDS
}

enum AiRequestStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PROCESSING
}

enum AuditActorType {
  USER
  SYSTEM
  CRON
  WORKER
  ADMIN
}

enum AuditEventType {
  CV_CREATED
  CV_UPDATED
  CV_SECTION_UPDATED
  CV_RESTORED
  SHARE_LINK_CREATED
  SHARE_LINK_DELETED
  BILLING_STATUS_CHANGED
  USER_ROLE_CHANGED
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ThumbnailStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model AuditLog {
  id            String         @id @default(uuid())
  actorUserId   String?
  actorType     AuditActorType
  eventType     AuditEventType
  action        String
  resourceType  String
  resourceId    String?
  oldValue      Json?
  newValue      Json?
  severity      AuditSeverity
  requestId     String?
  traceId       String?
  ipHash        String?
  createdAt     DateTime       @default(now())

  @@index([actorUserId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

enum SkillCategory {
  BACKEND
  FRONTEND
  DEVOPS
  CLOUD
  DATABASE
  MOBILE
  AI_ML
  SOFT_SKILL
}

enum SkillDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Skill {
  id             String            @id @default(cuid())
  name           String            @unique // VD: "Docker", "AWS", "Kubernetes"
  category       SkillCategory
  difficulty     SkillDifficulty   @default(BEGINNER)
  estimatedWeeks Int               @default(2)
  createdAt      DateTime          @default(now())

  dependencies   SkillDependency[] @relation("DependentSkills")
  neededFor      SkillDependency[] @relation("RequiredSkills")
  courses        Course[]
  phaseSkills    RoadmapPhaseSkill[]
  skillGaps      CareerSkillGap[]
}

model SkillDependency {
  id             String   @id @default(cuid())
  skillId        String
  dependsOnId    String
  createdAt      DateTime @default(now())

  skill          Skill    @relation("DependentSkills", fields: [skillId], references: [id], onDelete: Cascade)
  dependsOn      Skill    @relation("RequiredSkills", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([skillId, dependsOnId])
}

model Course {
  id          String      @id @default(cuid())
  title       String
  provider    String      // "YouTube", "FreeCodeCamp", "Internal"
  url         String
  skillId     String      // Hard relation với Skill.id
  level       CourseLevel @default(BEGINNER)
  durationMin Int?        // thời lượng tính bằng phút
  language    String      @default("en")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  skill       Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([provider, skillId])
}

model CareerRoadmap {
  id              String           @id @default(cuid())
  userId          String
  atsScanId       String?
  currentRole     String
  targetRole      String
  estimatedMonths Float
  explanation     String?          @db.Text
  status          RoadmapStatus    @default(GENERATING)
  progress        Int              @default(0) // Tiến trình tạo (%)
  failureReason   String?          // Lý do thất bại (OpenAI timeout, quota exceeded, etc.)
  failedAt        DateTime?        // Thời điểm ghi nhận lỗi (hữu ích khi debug production)
  version         Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  atsScan         AtsScan?         @relation(fields: [atsScanId], references: [id], onDelete: SetNull)
  phases          RoadmapPhase[]
  skillGaps       CareerSkillGap[]
  coachSessions   CareerCoachSession[]

  @@index([userId])
}

model RoadmapPhase {
  id         String              @id @default(cuid())
  roadmapId  String
  phaseIndex Int                 // Thứ tự phase (0, 1, 2...)
  phaseName  String              // Tên phase tự động ("Phase 1: Foundation", "Phase 2: Cloud"...)
  
  roadmap    CareerRoadmap       @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  skills     RoadmapPhaseSkill[]
}

model RoadmapPhaseSkill {
  id        String       @id @default(cuid())
  phaseId   String
  skillId   String
  order     Int          // Thứ tự học của skill trong phase này
  
  phase     RoadmapPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  skill     Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([phaseId, skillId])
  @@index([phaseId])
  @@index([skillId])
}

model CareerSkillGap {
  id              String        @id @default(cuid())
  roadmapId       String
  skillId         String
  priority        Int           // 1 (Highest), 2, 3...
  estimatedImpact Int           // Dự tính điểm cộng ATS (+5 cho Required, +2 cho Preferred, +1 cho Bonus)
  
  roadmap         CareerRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  skill           Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@index([skillId])
}

enum RoadmapStatus {
  GENERATING
  READY
  FAILED
  CANCELLED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CareerCoachRole {
  USER
  ASSISTANT
  SYSTEM
}

model CareerCoachSession {
  id            String   @id @default(cuid())
  roadmapId     String
  userId        String
  title         String   @default("General Career Coaching")
  archived      Boolean  @default(false)
  messageCount  Int      @default(0)
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roadmap       CareerRoadmap        @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      CareerCoachMessage[]

  @@index([roadmapId])
  @@index([userId])
  @@index([roadmapId, archived])
  @@index([lastMessageAt])
}

model CareerCoachMessage {
  id        String          @id @default(cuid())
  sessionId String
  role      CareerCoachRole
  content   String          @db.Text
  createdAt DateTime        @default(now())

  session   CareerCoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
}

enum AiFeature {
  CAREER_COACH
  ATS_REVIEW
  CV_REWRITE
  OCR
  SKILL_SUGGESTION
  GITHUB_ANALYSIS
}

enum AiProvider {
  OPENAI
  GEMINI
  CLAUDE
}

model AiUsageLog {
  id               String     @id @default(cuid())
  userId           String?
  feature          AiFeature
  provider         AiProvider
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Decimal    @db.Decimal(14, 8)
  requestId        String?
  success          Boolean
  createdAt        DateTime   @default(now())

  user             User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([feature])
  @@index([requestId])
  @@index([createdAt])
}


