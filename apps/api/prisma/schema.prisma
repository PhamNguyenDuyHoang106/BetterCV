generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  GUEST
  FREE
  PRO
  PREMIUM
  ADMIN
}

enum PlanTier {
  FREE
  PRO
  PREMIUM
}

enum OcrJobStatus {
  UPLOADED
  QUEUED
  PROCESSING
  REVIEWING
  COMPLETED
  FAILED
}

enum CvSectionType {
  PROFILE
  SUMMARY
  EXPERIENCE
  EDUCATION
  SKILLS
  PROJECTS
}

enum AiRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── Core Identity & Access ─────────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String?
  fullName      String
  avatarUrl     String?
  role          UserRole       @default(FREE)
  supabaseId    String?        @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  subscriptions Subscription[]
  cvs           Cv[]
  aiUsages      AiUsage[]
  usageQuota    UsageQuota?
  stripeCustomer StripeCustomer?
  ocrJobs       OcrJob[]
  invoices      Invoice[]

  @@index([email])
  @@index([supabaseId])
}

// ─── Plans & Billing ────────────────────────────────────────────────────────

model Plan {
  id             String         @id @default(cuid())
  tier           PlanTier       @unique
  name           String
  monthlyAiQuota Int
  stripePriceId  String?        @unique
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscriptions  Subscription[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId               String
  plan                 Plan      @relation(fields: [planId], references: [id])
  status               String
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model StripeCustomer {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId String   @unique
  createdAt  DateTime @default(now())
}

model Invoice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  currency  String   @default("usd")
  status    String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── CV & Templates ─────────────────────────────────────────────────────────

model Cv {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String
  locale                String      @default("en")
  templateId            String?
  templateVersionId     String?
  templateVersion       TemplateVersion? @relation(fields: [templateVersionId], references: [id])
  templateVersionNum    Int         @default(1)
  isDeleted             Boolean     @default(false)
  version               Int         @default(1)
  lastEditedSessionId   String?
  lastEditedDevice      String?
  lastEditedAt          DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  atsScore              Int?
  completenessScore     Int?
  thumbnailUrl          String?
  thumbnailGeneratedAt  DateTime?

  versions   CvVersion[]
  sections   CvSection[]
  shareLinks ShareLink[]
  atsScans   AtsScan[]

  @@index([userId])
  @@index([userId, isDeleted])
}

model CvVersion {
  id        String   @id @default(cuid())
  cvId      String
  cv        Cv       @relation(fields: [cvId], references: [id], onDelete: Cascade)
  snapshot  Json
  createdAt DateTime @default(now())

  @@index([cvId])
}

model CvSection {
  id        String        @id @default(cuid())
  cvId      String
  cv        Cv            @relation(fields: [cvId], references: [id], onDelete: Cascade)
  type      CvSectionType
  content   Json
  order     Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([cvId])
  @@index([cvId, type])
}

model TemplateCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  templates Template[]
}

model Template {
  id         String           @id @default(cuid())
  name       String
  categoryId String
  category   TemplateCategory @relation(fields: [categoryId], references: [id])
  schema     Json
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  versions   TemplateVersion[]

  @@index([categoryId])
  @@index([isActive])
}

model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  version    Int      @default(1)
  schema     Json
  createdAt  DateTime @default(now())

  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  cvs        Cv[]

  @@unique([templateId, version])
  @@index([templateId])
}

model ShareLink {
  id        String    @id @default(cuid())
  cvId      String
  cv        Cv        @relation(fields: [cvId], references: [id], onDelete: Cascade)
  token     String    @unique
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

model AtsScan {
  id                 String   @id @default(cuid())
  cvId               String
  cv                 Cv       @relation(fields: [cvId], references: [id], onDelete: Cascade)
  jobTitle           String?
  jobDescription     String?  @db.Text
  jobDescriptionHash String?
  overallScore       Int
  keywordScore       Int?
  formatScore        Int?
  completenessScore  Int?
  missingKeywords    Json?
  recommendations    Json?
  createdAt          DateTime @default(now())

  @@index([cvId, createdAt(sort: Desc)])
}

// ─── AI Orchestration ───────────────────────────────────────────────────────

model Prompt {
  id        String          @id @default(cuid())
  key       String          @unique
  createdAt DateTime        @default(now())
  versions  PromptVersion[]
}

model PromptVersion {
  id        String   @id @default(cuid())
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  version   Int
  content   String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([promptId, isActive])
}

model AiRequest {
  id              String          @id @default(cuid())
  userId          String?
  promptKey       String
  input           Json
  estimatedTokens Int?
  status          AiRequestStatus @default(PENDING)
  idempotencyKey  String?         @unique
  createdAt       DateTime        @default(now())

  @@index([userId])
  @@index([status, createdAt])
}

model AiResponse {
  id        String   @id @default(cuid())
  requestId String
  output    Json
  tokens    Int
  createdAt DateTime @default(now())

  @@index([requestId])
}

model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokens    Int
  requests  Int
  createdAt DateTime @default(now())

  @@index([userId])
}

model UsageQuota {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart  DateTime
  periodEnd    DateTime
  usedTokens   Int      @default(0)
  usedRequests Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SafetyRule {
  id        String   @id @default(cuid())
  name      String   @unique
  pattern   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model OcrJob {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename      String
  status        OcrJobStatus @default(UPLOADED)
  extractedCvId String?
  error         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
}
